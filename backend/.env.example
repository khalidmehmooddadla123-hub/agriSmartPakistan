# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/agrismart360?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# OpenWeatherMap API (FREE)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key

# Email (Gmail SMTP — FREE, use App Password)
# Enable 2FA, then create App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16char_app_password

# Twilio (for SMS/OTP — OPTIONAL, system falls back to console if not set)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Gemini AI (FREE — 15 req/min, 1M tokens/day)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Hugging Face Token (FREE — for ML-based disease detection)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token

# Frontend URL
CLIENT_URL=http://localhost:5173

# Pest Outbreak Detection Threshold (default: 5)
OUTBREAK_THRESHOLD=5
